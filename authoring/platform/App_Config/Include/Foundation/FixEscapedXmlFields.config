<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/">
  <sitecore>
    <events>
      <event name="item:saved">
        <handler
          type="XmCloudNextJsStarter.Events.FixEscapedXmlFields, XmCloudNextJsStarter"
          method="OnItemSaved">
          <ContentRootPath>/sitecore/content</ContentRootPath>
        </handler>
      </event>
    </events>
  </sitecore>
</configuration>